# Stage 1: Download corpus via sparse checkout
FROM python:3.12-slim AS corpus-downloader

RUN apt-get update && apt-get install -y git && rm -rf /var/lib/apt/lists/*

RUN git clone --depth 1 --filter=blob:none --sparse \
        https://github.com/databricks/officeqa.git /tmp/officeqa && \
    cd /tmp/officeqa && \
    git sparse-checkout set treasury_bulletins_parsed/transformed treasury_bulletins_parsed/jsons && \
    mkdir -p /corpus && \
    mv /tmp/officeqa/treasury_bulletins_parsed/transformed /corpus/transformed && \
    mv /tmp/officeqa/treasury_bulletins_parsed/jsons /corpus/jsons && \
    rm -rf /tmp/officeqa

# Stage 2: Final image
FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    "a2a-sdk[http-server]>=0.3.20" \
    "httpx>=0.28.1" \
    "pydantic>=2.11.0" \
    "python-dotenv>=1.1.1" \
    "uvicorn>=0.38.0" \
    "openai>=1.50.0" \
    "anthropic>=0.40.0" \
    "google-genai>=1.0.0" \
    "faiss-cpu>=1.7.4" \
    "numpy>=1.26.0" \
    "tiktoken>=0.7.0" \
    "rank-bm25>=0.2.2"

COPY --from=corpus-downloader /corpus /app/corpus

RUN mkdir -p /app/faiss_index

ENV CORPUS_DIR=/app/corpus/transformed
ENV FAISS_INDEX_DIR=/app/faiss_index

COPY participant/src/ ./

ENTRYPOINT ["python", "server.py"]
CMD ["--host", "0.0.0.0", "--port", "9019"]
EXPOSE 9019
