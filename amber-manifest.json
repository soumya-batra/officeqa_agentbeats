{
  "manifest_version": "0.1.0",
  "config_schema": {
    "type": "object",
    "properties": {
      "openai_api_key": { "type": "string", "secret": true }
    },
    "required": ["openai_api_key"],
    "additionalProperties": false
  },
  "program": {
    "image": "ghcr.io/zaidishahbaz1/officeqa-agent:latest",
    "entrypoint": ["python", "server.py", "--host", "0.0.0.0", "--port", "9019"],
    "env": {
      "PYTHONUNBUFFERED": "1",
      "OPENAI_API_KEY": "${config.openai_api_key}",
      "LLM_PROVIDER": "openai",
      "OPENAI_MODEL": "gpt-5.4",
      "ENABLE_WEB_SEARCH": "false",
      "REASONING_EFFORT": "medium",
      "CORPUS_DIR": "/app/corpus/transformed",
      "FAISS_INDEX_DIR": "/app/faiss_index"
    },
    "network": {
      "endpoints": [{ "name": "a2a_endpoint", "port": 9019 }]
    }
  },
  "provides": {
    "a2a": { "kind": "a2a", "endpoint": "a2a_endpoint" }
  },
  "exports": {
    "a2a": "a2a"
  },
  "metadata": {
    "agentbeats_id": "019d7202-fad7-71f0-9a15-62bb3faa4104"
  }
}
