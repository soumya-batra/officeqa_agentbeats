{
  "manifest_version": "0.1.0",
  "config_schema": {
    "type": "object",
    "properties": {
      "nebius_api_key": { "type": "string", "secret": true },
      "nebius_model": { "type": "string", "default": "moonshotai/Kimi-K2.5-fast" },
      "nebius_base_url": { "type": "string", "default": "https://api.studio.nebius.com/v1/" }
    },
    "required": ["nebius_api_key"],
    "additionalProperties": false
  },
  "program": {
    "image": "ghcr.io/soumya-batra/officeqa-agent:latest",
    "entrypoint": ["python", "server.py", "--host", "0.0.0.0", "--port", "9019"],
    "env": {
      "PYTHONUNBUFFERED": "1",
      "LLM_PROVIDER": "nebius",
      "NEBIUS_API_KEY": "${config.nebius_api_key}",
      "NEBIUS_MODEL": "${config.nebius_model}",
      "NEBIUS_BASE_URL": "${config.nebius_base_url}",
      "ENABLE_WEB_SEARCH": "false",
      "RETRIEVAL_TOP_K": "8",
      "CORPUS_DIR": "/app/corpus/transformed",
      "FAISS_INDEX_DIR": "/app/faiss_index"
    },
    "network": {
      "endpoints": [{ "name": "a2a_endpoint", "port": 9019 }]
    }
  },
  "provides": {
    "a2a": { "kind": "a2a", "endpoint": "a2a_endpoint" }
  },
  "exports": {
    "a2a": "a2a"
  },
  "metadata": {
    "agentbeats_id": "019d7202-fad7-71f0-9a15-62bb3faa4104"
  }
}
